rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /products/{docId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /sales/{docId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /sale_batches/{docId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /sale_batch_items/{docId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /product_templates/{docId} {
      allow read, create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /purchase_location_settings/{docId} {
      allow read, create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /jan_master/{janCode} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.janCode == janCode
        && request.resource.data.productName is string;
      allow delete: if false;
    }

    match /user_jan_usage/{docId} {
      allow read, create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
